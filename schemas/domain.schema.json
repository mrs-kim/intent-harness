{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "domain.schema.json",
  "title": "Domain",
  "description": "A stable bounded context owned by a team. Never completed, only evolved. The unit of ownership that survives attrition.",
  "type": "object",
  "required": ["id", "type", "title", "description", "owner-team", "boundary", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^dom_[a-z0-9]{6,12}$"
    },
    "type": {
      "type": "string",
      "const": "domain"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "description": "What this domain is responsible for in plain language."
    },
    "owner-team": {
      "type": "string",
      "description": "Team name, not individual. Ownership survives personnel changes."
    },
    "boundary": {
      "type": "object",
      "required": ["includes", "excludes"],
      "additionalProperties": false,
      "properties": {
        "includes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "What concerns belong to this domain."
        },
        "excludes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What concerns explicitly do not belong here, even if related."
        }
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^dom_[a-z0-9]{6,12}$" },
          "description": "Domains this domain depends on."
        },
        "related": {
          "type": "array",
          "items": { "type": "string", "pattern": "^dom_[a-z0-9]{6,12}$" }
        }
      }
    },
    "status": {
      "type": "object",
      "required": ["lifecycle"],
      "additionalProperties": false,
      "properties": {
        "lifecycle": {
          "type": "string",
          "enum": ["active", "historical"]
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created": { "type": "string", "format": "date" },
        "updated": { "type": "string", "format": "date" }
      }
    }
  }
}
